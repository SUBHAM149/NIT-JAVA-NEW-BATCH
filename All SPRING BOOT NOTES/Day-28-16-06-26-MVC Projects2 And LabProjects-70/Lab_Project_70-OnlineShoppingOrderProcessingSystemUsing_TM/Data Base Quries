Create Database
CREATE DATABASE shoppingdb;

USE shoppingdb;
Create Product Table
CREATE TABLE product
(
    productId INT PRIMARY KEY,
    productName VARCHAR(50),
    price DOUBLE,
    stock INT
);
Create Orders Table
CREATE TABLE orders
(
    orderId INT PRIMARY KEY,
    customerId INT,
    productId INT,
    quantity INT,
    totalAmount DOUBLE
);
