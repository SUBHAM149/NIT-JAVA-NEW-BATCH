package com.bank.transaction;

import java.sql.*;
import java.util.Scanner;

public class BankCRUDSystem {

    static final String URL = "jdbc:mysql://localhost:3306/jdbc_db_54";
    static final String USER = "root";
    static final String PASSWORD = "Subham@123";

    static Scanner sc = new Scanner(System.in);

    public static void main(String[] args) {

        try {
            Class.forName("com.mysql.cj.jdbc.Driver");
            Connection conn = DriverManager.getConnection(URL, USER, PASSWORD);

            int choice;

            do {
                System.out.println("\n===== BANK CRUD MENU =====");
                System.out.println("1. Create Account");
                System.out.println("2. View All Accounts");
                System.out.println("3. Update Account");
                System.out.println("4. Delete Account");
                System.out.println("5. Deposit");
                System.out.println("6. Withdraw");
                System.out.println("7. Transfer (Transaction)");
                System.out.println("0. Exit");
                System.out.print("Enter choice: ");

                choice = sc.nextInt();
                sc.nextLine();

                switch (choice) {
                    case 1 -> createAccount(conn);
                    case 2 -> viewAll(conn);
                    case 3 -> updateAccount(conn);
                    case 4 -> deleteAccount(conn);
                    case 5 -> deposit(conn);
                    case 6 -> withdraw(conn);
                    case 7 -> transfer(conn);
                    case 0 -> System.out.println("Exiting...");
                    default -> System.out.println("Invalid choice");
                }

            } while (choice != 0);

            conn.close();

        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    // 🔹 CREATE
    static void createAccount(Connection conn) throws SQLException {
        System.out.print("Enter Name: ");
        String name = sc.nextLine();

        System.out.print("Enter Email: ");
        String email = sc.nextLine();

        System.out.print("Enter Phone: ");
        String phone = sc.nextLine();

        System.out.print("Enter Balance: ");
        double balance = sc.nextDouble();

        PreparedStatement ps = conn.prepareStatement(
                "INSERT INTO bankdb(name, balance, email, phone) VALUES (?, ?, ?, ?)");
        ps.setString(1, name);
        ps.setDouble(2, balance);
        ps.setString(3, email);
        ps.setString(4, phone);

        ps.executeUpdate();
        System.out.println("✅ Account Created");
    }

    // 🔹 READ
    static void viewAll(Connection conn) throws SQLException {
        Statement st = conn.createStatement();
        ResultSet rs = st.executeQuery("SELECT * FROM bankdb");

        System.out.println("\n--- All Accounts ---");
        while (rs.next()) {
            System.out.println(
                    rs.getInt("id") + " | " +
                    rs.getString("name") + " | " +
                    rs.getDouble("balance") + " | " +
                    rs.getString("email") + " | " +
                    rs.getString("phone"));
        }
    }

    // 🔹 UPDATE
    static void updateAccount(Connection conn) throws SQLException {
        System.out.print("Enter ID to update: ");
        int id = sc.nextInt();
        sc.nextLine();

        System.out.print("Enter New Email: ");
        String email = sc.nextLine();

        System.out.print("Enter New Phone: ");
        String phone = sc.nextLine();

        PreparedStatement ps = conn.prepareStatement(
                "UPDATE bankdb SET email=?, phone=? WHERE id=?");
        ps.setString(1, email);
        ps.setString(2, phone);
        ps.setInt(3, id);

        int rows = ps.executeUpdate();
        System.out.println(rows > 0 ? "✅ Updated" : "❌ ID not found");
    }

    // 🔹 DELETE
    static void deleteAccount(Connection conn) throws SQLException {
        System.out.print("Enter ID to delete: ");
        int id = sc.nextInt();

        PreparedStatement ps = conn.prepareStatement(
                "DELETE FROM bankdb WHERE id=?");
        ps.setInt(1, id);

        int rows = ps.executeUpdate();
        System.out.println(rows > 0 ? "✅ Deleted" : "❌ ID not found");
    }

    // 🔹 DEPOSIT
    static void deposit(Connection conn) throws SQLException {
        System.out.print("Enter ID: ");
        int id = sc.nextInt();

        System.out.print("Enter Amount: ");
        double amt = sc.nextDouble();

        PreparedStatement ps = conn.prepareStatement(
                "UPDATE bankdb SET balance = balance + ? WHERE id=?");
        ps.setDouble(1, amt);
        ps.setInt(2, id);

        int rows = ps.executeUpdate();
        System.out.println(rows > 0 ? "✅ Deposit Done" : "❌ ID not found");
    }

    // 🔹 WITHDRAW
    static void withdraw(Connection conn) throws SQLException {
        System.out.print("Enter ID: ");
        int id = sc.nextInt();

        System.out.print("Enter Amount: ");
        double amt = sc.nextDouble();

        PreparedStatement check = conn.prepareStatement(
                "SELECT balance FROM bankdb WHERE id=?");
        check.setInt(1, id);
        ResultSet rs = check.executeQuery();

        if (rs.next()) {
            double bal = rs.getDouble("balance");

            if (bal < amt) {
                System.out.println("❌ Insufficient Balance");
                return;
            }

            PreparedStatement ps = conn.prepareStatement(
                    "UPDATE bankdb SET balance = balance - ? WHERE id=?");
            ps.setDouble(1, amt);
            ps.setInt(2, id);
            ps.executeUpdate();

            System.out.println("✅ Withdraw Done");
        } else {
            System.out.println("❌ ID not found");
        }
    }

    // 🔹 TRANSFER (Transaction)
    static void transfer(Connection conn) throws SQLException {

        System.out.print("Sender ID: ");
        int sender = sc.nextInt();

        System.out.print("Receiver ID: ");
        int receiver = sc.nextInt();

        System.out.print("Amount: ");
        double amt = sc.nextDouble();

        try {
            conn.setAutoCommit(false);

            // check balance
            PreparedStatement check = conn.prepareStatement(
                    "SELECT balance FROM bankdb WHERE id=?");
            check.setInt(1, sender);
            ResultSet rs = check.executeQuery();

            if (!rs.next() || rs.getDouble("balance") < amt) {
                System.out.println("❌ Transfer Failed");
                return;
            }

            // debit
            PreparedStatement debit = conn.prepareStatement(
                    "UPDATE bankdb SET balance = balance - ? WHERE id=?");
            debit.setDouble(1, amt);
            debit.setInt(2, sender);
            debit.executeUpdate();

            // credit
            PreparedStatement credit = conn.prepareStatement(
                    "UPDATE bankdb SET balance = balance + ? WHERE id=?");
            credit.setDouble(1, amt);
            credit.setInt(2, receiver);

            int rows = credit.executeUpdate();
            if (rows == 0) throw new SQLException();

            conn.commit();
            System.out.println("✅ Transfer Successful");

        } catch (Exception e) {
            conn.rollback();
            System.out.println("❌ Transfer Failed (Rollback)");
        } finally {
            conn.setAutoCommit(true);
        }
    }
}
