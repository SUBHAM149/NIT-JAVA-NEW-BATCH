package com.sub.callabelestatement;

import java.sql.CallableStatement;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.SQLException;

public class DemoInserOperation {

	public static void main(String[] args) throws ClassNotFoundException, SQLException {
		Class.forName("com.mysql.cj.jdbc.Driver");
		Connection c=DriverManager.getConnection("jdbc:mysql://localhost:3306/callable_db", "root", "Subham@123");
		
		CallableStatement cs= c.prepareCall("{call insertemp(?,?,?,?)}");
		cs.setInt(1, 200);
		cs.setString(2, "Raj");
		cs.setString(3, "CS");
		cs.setInt(4, 2000);
		
		int rows=cs.executeUpdate();
		System.out.println("No of rows inserted is: "+rows);
		c.close();
		

	}

}
