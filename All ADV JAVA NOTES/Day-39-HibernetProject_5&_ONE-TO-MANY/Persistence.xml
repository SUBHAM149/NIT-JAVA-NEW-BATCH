<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
            version="3.0">

   <persistence-unit name="subh">

       <!-- Hibernate Provider -->
       <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

       <!-- Entity Classes (IMPORTANT) -->
       <class>com.nit.dto.Mobile</class>
       <class>com.nit.dto.SimCard</class>

       <properties>

           <!-- Database Connection -->
           <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
           <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/one_to_many_db_54"/>
           <property name="jakarta.persistence.jdbc.user" value="root"/>
           <property name="jakarta.persistence.jdbc.password" value="Subham@123"/>

           <!-- Hibernate Settings -->
           <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>
           <property name="hibernate.show_sql" value="true"/>
           <property name="hibernate.format_sql" value="true"/>

           <!-- Auto Table Creation -->
           <property name="hibernate.hbm2ddl.auto" value="update"/>

       </properties>

   </persistence-unit>

</persistence>
