-- ✅ 1. Display sales details with customer details

SELECT s.dateid, s.prodid, s.custid, s.qty, s.amount,
       c.cname, c.city, c.state, c.country
FROM SALES s
JOIN CUST c
ON s.custid = c.custid;



-- ✅ 2. Display sales details with product details

SELECT s.dateid, s.prodid, s.custid, s.qty, s.amount,
       p.pname, p.category, p.brand
FROM SALES s
JOIN PRODUCTS p
ON s.prodid = p.prodid;



-- ✅ 3. Display sales details with product details with customer details

SELECT s.dateid, s.qty, s.amount,
       p.pname, p.category, p.brand,
       c.cname, c.city, c.country
FROM SALES s
JOIN PRODUCTS p
ON s.prodid = p.prodid
JOIN CUST c
ON s.custid = c.custid;



-- ✅ 4. Display category wise total amount

SELECT p.category, SUM(s.amount) AS total_amount
FROM SALES s
JOIN PRODUCTS p
ON s.prodid = p.prodid
GROUP BY p.category;



-- ✅ 5. Display brand wise total quantity

SELECT p.brand, SUM(s.qty) AS total_quantity
FROM SALES s
JOIN PRODUCTS p
ON s.prodid = p.prodid
GROUP BY p.brand;



-- ✅ 6. Display country wise total amount in the year 2025

SELECT c.country, SUM(s.amount) AS total_amount
FROM SALES s
JOIN CUST c
ON s.custid = c.custid
WHERE EXTRACT(YEAR FROM s.dateid) = 2025
GROUP BY c.country;



-- ✅ 7. Display country wise, category wise total amount

SELECT c.country, p.category, SUM(s.amount) AS total_amount
FROM SALES s
JOIN CUST c
ON s.custid = c.custid
JOIN PRODUCTS p
ON s.prodid = p.prodid
GROUP BY c.country, p.category;
