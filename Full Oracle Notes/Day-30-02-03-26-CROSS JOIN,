  -- =========================================
-- 1️⃣ CREATE TABLES
-- =========================================

CREATE TABLE PRODUCTS (
    prodid NUMBER PRIMARY KEY,
    pname VARCHAR2(50),
    price NUMBER,
    category VARCHAR2(50),
    brand VARCHAR2(50)
);

CREATE TABLE CUST (
    custid NUMBER PRIMARY KEY,
    cname VARCHAR2(50),
    addr VARCHAR2(100),
    city VARCHAR2(50),
    state VARCHAR2(50),
    country VARCHAR2(50)
);

CREATE TABLE SALES (
    dateid DATE,
    prodid NUMBER,
    custid NUMBER,
    qty NUMBER,
    amount NUMBER,
    FOREIGN KEY (prodid) REFERENCES PRODUCTS(prodid),
    FOREIGN KEY (custid) REFERENCES CUST(custid)
);


