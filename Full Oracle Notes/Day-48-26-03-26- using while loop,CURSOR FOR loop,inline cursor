  => wap to find max sal without using max function ?

     DECLARE
         m  NUMBER := 0;
     BEGIN
         FOR r IN (SELECT sal FROM emp)
         LOOP
             IF r.sal > m THEN
                 m := r.sal;
             END IF;
        END LOOP;
        DBMS_OUTPUT.PUT_LINE(m);
    END;
