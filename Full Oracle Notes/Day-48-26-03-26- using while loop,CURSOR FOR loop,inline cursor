  using while loop :- 
  --------------------------

     DECLARE
             CURSOR C1 IS SELECT  ename,sal FROM emp ;
             vename emp.ename%TYPE;
             vsal  emp.sal%TYPE;
         BEGIN
              OPEN C1;
              FETCH C1 INTO  vename,vsal;
              WHILE(C1%FOUND)
        LOOP 
              DBMS_OUTPUT.PUT_LINE(vename||'   '||vsal);
              FETCH C1 INTO  vename,vsal;
         END LOOP;
             CLOSE C1;
       END;
         /

CURSOR FOR loop  :- 
-------------------------------

   FOR  var  IN  <CURSOR-NAME>
  LOOP
    statements ; 
 END LOOP;

 Ex :- 

  FOR r IN C1                                  
  LOOP                           
   statements ; 
 END LOOP;

 => loop is executed no of times depends on no of rows in cursor.

 => adv of  cursor for loop is opening ,fetching and closing is not required and these
       operations performed implicitly.

 => every time loop executes a record is fetched from cursor and assigned to variable "r"

 => loop variable "r" is also declared implicitly as rowtype

  Ex :- 

    DECLARE
       CURSOR C1 IS SELECT  ename,sal FROM emp ;
    BEGIN
        FOR r IN C1
       LOOP
             DBMS_OUTPUT.PUT_LINE(r.ename||'   '||r.sal);
       END LOOP;
  END;
     /

