=> wap  to find min sal ? 

     DECLARE
         CURSOR C1 IS SELECT sal FROM emp;
         m  NUMBER ;
         vsal  NUMBER;
     BEGIN
         OPEN C1;
         FETCH C1 INTO m;
      LOOP
         FETCH  C1 INTO vsal;
         EXIT WHEN C1%NOTFOUND;
         IF vsal < m THEN
             m := vsal;
        END IF;
     END LOOP;
     DBMS_OUTPUT.PUT_LINE(m);
     CLOSE C1;
   END;
     /

   DECLARE
         CURSOR C1 IS SELECT sal FROM emp;
         m  NUMBER ;
         vsal  NUMBER;
     BEGIN
         OPEN C1;
         FETCH C1 INTO m;
         CLOSE C1;
         FOR r IN C1
      LOOP
            IF r.sal < m THEN
                 m := r.sal;
            END IF;
       END LOOP;
       DBMS_OUTPUT.PUT_LINE(m);
   END;
       /

