 LAG / LEAD :- 
 -------------------

    LAG(colname,INT)  OVER (ORDER BY ---)     => returns previous row value
    LEAD(colname,INT) OVER (ORDER BY ---)   => returns prevous row value

 Ex 1 :- 

 SELECT empno,ename,sal,
               LAG(sal,1) OVER (ORDER BY empno ASC) as prev_sal
