 => wap to input empno and calculate and print experience of the employee ?

   DECLARE
        vempno  NUMBER(4);
        vhire       DATE;
        vexpr      NUMBER(2);
  BEGIN
       vempno := &empno;
       SELECT  hiredate INTO vhire FROM emp WHERE empno = vempno ; 
       vexpr :=  (SYSDATE - vhire)/365 ;
       DBMS_OUTPUT.PUT_LINE('Experience =  '||vexpr||' years');
  END;
    /

