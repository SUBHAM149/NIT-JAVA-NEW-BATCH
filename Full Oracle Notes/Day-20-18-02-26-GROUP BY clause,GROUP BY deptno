 => display year wise no of employees joined ?

  SELECT TO_CHAR(hiredate,'yyyy') as year,COUNT(*)
  FROM emp 
  GROUP BY TO_CHAR(hiredate,'yyyy')
  ORDER BY year ASC ; 

           GROUP BY   year      INVALID
           ORDER BY   year      VALID

  NOTE :- 

   => column alias cannot be used in group by clause because group by  is executed
        before select.

   => column alias can be used in order by clause because order by is executed after select

 => display day wise no of employees ?

  SELECT   TO_CHAR(hiredate,'day') as day,COUNT(*)
  FROM emp 
  GROUP BY  TO_CHAR(hiredate,'day')
  ORDER BY  day ASC ; 
 
 => display months wise no of employees joined in the year  1981 ? 

  SELECT TO_CHAR(hiredate,'mon') as  month,COUNT(*)
  FROM emp 
  WHERE TO_CHAR(hiredate,'yyyy') = 1981 
  GROUP BY TO_CHAR(hiredate,'mon')
  ORDER BY month ASC ; 

 => find the departments having more than 3 employees ? 
  
      SELECT deptno,COUNT(*) as cnt
      FROM emp 
      WHERE COUNT(*) > 3 
      GROUP BY deptno  ;           => ERROR

    => oracle cannot calculate dept wise count before group by and it can calculate
         only after group by , so apply the condition COUNT(*) > 3 after group by 
         using HAVING clause.

      SELECT deptno,COUNT(*) as cnt
      FROM emp 
      GROUP BY deptno       
      HAVING COUNT(*) > 3  ;

	20	5
	30	6

 WHERE VS HAVING :-
 -------------------------------

	WHERE				HAVING

 1    selects specific rows			selects specific groups 

2     conditions applied before group by		conditions applied after group by 

3     use where clause if cond			use having clause if cond
       doesn't contain aggregate 			contains aggregate function
       function

