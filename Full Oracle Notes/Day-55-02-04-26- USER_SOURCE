 =>  create a function to calculate total amount of particular order ?

   orders					products
   ordid	prodid	qty			prodid	pname	price
  1000	100	2			100	A	1000
  1000	101	3			101	B	500
  1000	102	1			102	C	1500
  1001	100	2

                               input :-   ordid  =  1000
                              output     amount =  5000

  CREATE OR REPLACE FUNCTION getOrdAmt
  (
     pordid  IN  NUMBER
  )  RETURN  NUMBER
  IS
    CURSOR C1 IS   SELECT  o.prodid,o.qty,p.price
                                 FROM orders o INNER JOIN products p
                                 ON o.prodid = p.prodid
                                 WHERE o.ordid = pordid;
    total   NUMBER := 0;
 BEGIN
    FOR r  IN C1
    LOOP
       total  :=  total + (r.qty * r.price);
    END LOOP;
    RETURN total;
  END;
  /

C1
 prodid	qty	price
 100	2	1000  
 101	3	500    
 102	1	1500	=> r 


 Execution :-
 ----------------
 
 SELECT  getOrdAmt(1000) FROM DUAL ;    => 5000

 SELECT  getOrdAmt(1001) FROM DUAL  ;  =>  2000
 
