while loop :-
----------------

DECLARE
   x  NUMBER(2) := 1;
BEGIN
   WHILE(x<=10)
   LOOP
       DBMS_OUTPUT.PUT_LINE(x);
       x := x +1;
   END LOOP;
 END;
   /

FOR loop :-
----------------

 BEGIN
      FOR  x  IN  1..10
      LOOP
         DBMS_OUTPUT.PUT_LINE(x);
      END LOOP;
 END;
