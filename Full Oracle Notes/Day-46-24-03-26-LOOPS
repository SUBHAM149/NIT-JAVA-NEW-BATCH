 => wap to input number and print whether it is prime or not ?
SET SERVEROUTPUT ON;

DECLARE
    n NUMBER := &num;   -- Input number
    i NUMBER;
    flag NUMBER := 0;
BEGIN
    IF n <= 1 THEN
        DBMS_OUTPUT.PUT_LINE('Not a Prime Number');
    ELSE
        FOR i IN 2..n-1 LOOP
            IF MOD(n, i) = 0 THEN
                flag := 1;
                EXIT;
            END IF;
        END LOOP;

        IF flag = 0 THEN
            DBMS_OUTPUT.PUT_LINE('Prime Number');
        ELSE
            DBMS_OUTPUT.PUT_LINE('Not a Prime Number');
        END IF;
    END IF;
END;
/
