DECLARE
         d1   DATE;
         d2   DATE;
         cnt   NUMBER := 0;
   BEGIN
         d1 := '01-MAR-26' ;
         d2 := '31-MAR-26';
         d1 := NEXT_DAY(d1-1,'sunday');
         WHILE(d1 <= d2)
         LOOP
               DBMS_OUTPUT.PUT_LINE(d1||'      '||TO_CHAR(d1,'day'));
                cnt := cnt + 1;
                d1 := d1+7;
          END LOOP;
          DBMS_OUTPUT.PUT_LINE('No of sundays = '||cnt);
   END;
