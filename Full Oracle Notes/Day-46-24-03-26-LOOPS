 => wap to print sundays between two given dates ? 

   DECLARE
         d1   DATE;
         d2   DATE;
   BEGIN
         d1 := '01-JAN-26' ;
         d2 := '31-DEC-26';
         WHILE(d1 <= d2)
         LOOP
                IF TO_CHAR(d1,'fmday') = 'sunday' THEN
                    DBMS_OUTPUT.PUT_LINE(d1||'      '||TO_CHAR(d1,'day'));
              END IF;
                d1 := d1+1;
          END LOOP;
