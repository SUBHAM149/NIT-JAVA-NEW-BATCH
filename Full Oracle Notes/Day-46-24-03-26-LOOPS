 simple loop :-
 -----------------

  DECLARE
      x   NUMBER(2)  := 1 ;
  BEGIN
     LOOP
        DBMS_OUTPUT.PUT_LINE(x);
        x := x+1;
        EXIT WHEN x > 10;
   END LOOP;
 END;
