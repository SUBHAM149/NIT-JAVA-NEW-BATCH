ROWNUM :-
----------------

 => returns record numbers for the records return by select query
 => rownum is also a psuedo column like rowid

   SELECT rownum,empno,ename,sal FROM emp ;       

        	  9       7839 king             5000

    SELECT rownum,empno,ename,sal FROM emp WHERE sal >= 2000;

      	   5       7839 king             5000

      SELECT rownum,empno,ename,sal FROM emp WHERE sal >= 3000; 

  	   2       7839 king             5000

  note :- rownum is not baesd on table and it is based on select stmt output ,
             if select stmt output changes rownum also changes 

  => display first 5 rows from emp ?

      SELECT empno,ename,sal
      FROM emp 
      WHERE rownum <= 5 ; 

 => display 5th row ?

      SELECT empno,ename,sal
      FROM emp 
      WHERE rownum = 5 ;   => no rows 

  with rownum   =    >    >=  will not work  only    <     <=  will work , to overcome this
  use INLINE views 

      SELECT *
      FROM  (SELECT rownum as rno,empno,ename,sal FROM emp)  e
      WHERE rno = 5 ; 

      WHERE rno  IN (5,10,15)       

      WHERE rno BETWEEN 5 AND 10 

      WHERE MOD(rno,2) = 0 

      WHERE MOD(rno,5) = 0

     => display last 3 rows ?

      SELECT *
      FROM  (SELECT rownum as rno,empno,ename,sal FROM emp)  e
      WHERE  rno >= (SELECT COUNT(*)-2 FROM emp)  ; 
