  => create trigger to not to allow the user to decrement salary ? 

    CREATE OR REPLACE TRIGGER TRG4
    BEFORE UPDATE
    ON emp 
    FOR EACH ROW
    BEGIN
              IF  :NEW.SAL < :OLD.SAL THEN
                    RAISE_APPLICATION_ERROR(-20001,'sal cannot be decremented');
             END IF;
   END;
