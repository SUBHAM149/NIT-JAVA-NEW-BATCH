 Auditing :- 
 ---------------

   => Auditing means monitoring day-to-day activities on tables
   => Triggers are created for auditing
   
  EMP_AUDIT
  uname	 operation	    optime      new_empno   new_ename   new_sal    old_empno   old_ename  old_sal
   
CREATE TABLE emp_audit
(
   uname  VARCHAR2(10),
   operation VARCHAR2(10),
   optime     DATE,
   new_empno NUMBER(4),
   new_ename  VARCHAR2(10),
   new_sal   NUMBER(7,2),
   old_empno NUMBER(4),
   old_ename  VARCHAR2(10),
   old_sal   NUMBER(7,2)
  );

 => create trigger to insert details into emp_audit table whenever user insert/update/delete ?

  CREATE OR REPLACE TRIGGER TRG6
  AFTER  INSERT OR UPDATE OR DELETE
  ON emp
  FOR EACH ROW
  DECLARE
            OP   VARCHAR2(10);
  BEGIN
        IF  INSERTING THEN
              OP := 'INSERT' ;
        ELSIF DELETING THEN
              OP := 'DELETE';
        ELSE
              OP := 'UPDATE';
         END IF;
         INSERT INTO emp_audit 
            VALUES(user,OP,SYSDATE,:new.empno,:new.ename,:new.sal,:old.empno,:old.ename,:old.sal);
 END;
   /
 

