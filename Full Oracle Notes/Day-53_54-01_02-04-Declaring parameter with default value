procedure to issue book to student :-
----------------------------------------------------

 CREATE OR REPLACE PROCEDURE issue_book
 (
     pbookid  IN NUMBER,
     pmemid  IN  NUMBER
 )
 IS
   x   NUMBER;
 BEGIN
     SELECT  no_of_copies INTO x  FROM book  WHERE  book_id = pbookid;
     IF x = 0 THEN
         RAISE_APPLICATION_ERROR(-20001,'book not available');
   END IF;
   INSERT INTO book_issue VALUES(pbookid,pmemid,SYSDATE,SYSDATE+7);
   UPDATE book SET no_of_copies = no_of_copies - 1 WHERE book_id = pbookid ;
   COMMIT;
 END;
 /

