 => create a function to check whether year is leap year or not ?

  CREATE OR REPLACE 
      FUNCTION IS_LEAP(y  NUMBER) RETURN  VARCHAR2
 IS
   d  DATE;
 BEGIN
     d :=  '29-FEB-'||y;
     RETURN 'leap year';
  EXCEPTION
    WHEN OTHERS THEN
           RETURN 'not a leap year';
 END;
 /

 SELECT IS_LEAP(2024) FROM DUAL ;

leap year

SQL> SELECT IS_LEAP(2025) FROM DUAL ;

