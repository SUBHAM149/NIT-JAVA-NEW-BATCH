 => display dept wise total salaries ?
      display only 10 & 20 dept ?
      display the departments where total sal > 10000 ?

     SELECT deptno,SUM(sal)
     FROM emp
     WHERE  deptno IN (10,20)
     GROUP BY deptno 
     HAVING   SUM(sal) > 10000 ;

