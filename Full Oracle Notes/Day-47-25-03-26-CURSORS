  => wap to input string and print reverse ? 
       and check whether string is palindrome or not ?

   DECLARE
     s1   VARCHAR2(20);
     s2   VARCHAR2(20);
  BEGIN
      s1  := '&string';         
      FOR x  IN 1..LENGTH(s1)
      LOOP
          s2 :=  s2||SUBSTR(s1,-x,1);
      END LOOP;
      DBMS_OUTPUT.PUT_LINE(s2);
      IF s1 = s2 THEN
           DBMS_OUTPUT.PUT_LINE('palindrome');
      ELSE
           DBMS_OUTPUT.PUT_LINE('not a palindrome');
      END IF;
  END;
  /
 
=> wap to print prime numbers upto 20 ? 

    DECLARE   
       b  BOOLEAN ;
   BEGIN
   FOR num IN 1..20
 LOOP
       b := FALSE;
      FOR x  IN  2..num/2
      LOOP
             IF MOD(num,x) =0 THEN
                       b := TRUE;
                       exit;
             END IF;
       END LOOP;
      IF b=FALSE THEN
           DBMS_OUTPUT.PUT_LINE(num);
       END IF;
 END LOOP;
   END;
