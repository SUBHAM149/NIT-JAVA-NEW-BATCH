FOREIGN KEY :-
-----------------------

 =>  foreign key is used to establish relationship between two tables
 
 => To establish relationship between two tables , take primary key of one
       table and add it to another table as foreign key and declare with
       references constraint.

ex :- 

 DEPT
 dno	dname	
10	HR
20	IT
30	SALES

EMP
empno	ename	sal	dno     REFERENCES  dept(dno)
1	A	4000	10
2	B	5000         20
3	C	3000         90  => invalid
4	D	4000	10
5	E	2000	NULL

=> values entered in fk column should match with values entered in pk column 
=> fk allows duplicates and nulls
=> after declaring fk a relationship is created between two tables called parent / child
     relationship 
=> pk table is parent and fk table is child

CREATE TABLE dept55
(
  dno  NUMBER(2) PRIMARY KEY,
  dname VARCHAR2(10) NOT NULL
);
 INSERT INTO dept55 VALUES(10,'HR');
 INSERT INTO dept55 VALUES(20,'IT');

CREATE TABLE emp55
(
  empno NUMBER(4) PRIMARY KEY,
  ename VARCHAR2(10) NOT NULL,
  sal  NUMBER(7)  CHECK(sal>=3000),
  dno  NUMBER(2)  REFERENCES dept55(dno)
);

INSERT INTO emp55 VALUES(1,'A',3000,10);
 INSERT INTO emp55 VALUES(2,'B',4000,90); => ERROR
 INSERT INTO emp55 VALUES(3,'C',54000,10);
 INSERT INTO emp55 VALUES(4,'D',3000,NULL);

