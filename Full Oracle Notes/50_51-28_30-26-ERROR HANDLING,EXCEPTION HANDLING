 SYSTEM DEFINED :- 
 =================

 => errors raised by oracle are called system defined errors 

 1  zero_divide		=>    raised when we try to divide a number with 0
 2  value_error                          =>     raised when value exceeds variable size
 3  invalid_number		=>    raised when invalid calculation performed
 4  no_data_found 	                =>     raised when data not found in the table
 5  too_many_rows                   =>     raised when select stmt fetches more than one row
 6  dup_val_on_index               =>     raised when we try to insert duplicate value into primary key column
 7  cursor_already_open           =>    raised when we try to open cursor which is already opened

 EXCEPTION
    WHEN ZERO_DIVIDE THEN
         statements;
    WHEN VALUE_ERROR THEN
         statements;
    WHEN others THEN
          statements;
 END;
  /

  Ex 1 :- 

  DECLARE
     a  NUMBER(3);
     b  NUMBER(3);
     c  NUMBER(3);
 BEGIN
     a := &a;
     b := &b;
     c := a/b;
     DBMS_OUTPUT.PUT_LINE(c);
 EXCEPTION
    WHEN ZERO_DIVIDE THEN
        DBMS_OUTPUT.PUT_LINE('divisor cannot be zero');
   WHEN VALUE_ERROR THEN
       DBMS_OUTPUT.PUT_LINE('value exceeding size');
 END;
  /

